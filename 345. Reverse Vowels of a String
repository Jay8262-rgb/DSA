<h1>This leetcode problem solve through two pointer approch<h1/>


class Solution {
    private boolean isVowel(char ch) {
        return "aeiouAEIOU".indexOf(ch) != -1; // this method i used to managing time without this not work perfectly show time limit excedded
    }
    public String reverseVowels(String s) {
        int n = s.length() - 1;
        int start = 0;
        int end = s.length()-1;
        char[] ch = s.toCharArray();
        while(start < end){
            if(!isVowel(ch[start])){    
                start++;
            }
            else if(!isVowel(ch[end])){
                end--;
            }
            else{
                char temp = ch[start];
                ch[start] = ch[end];
                ch[end] = temp;
                start++;
                end--;
            }
        }
        return new String(ch);
    }
}
